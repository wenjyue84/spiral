# SPIRAL environment variable reference
# Copy to .env or export these in your shell before running spiral.sh.
# All variables are optional — defaults are shown in comments.

# ── cgroups v2 per-worker isolation (Linux only, US-259) ────────────────────
# Kernel-enforced hard memory and CPU limits applied to each Ralph worker
# subprocess via cgroups v2. Automatically skipped with a warning on macOS,
# Windows, or kernels without cgroups v2 (missing /sys/fs/cgroup/cgroup.controllers).
#
# Hard memory limit per worker in MB (memory.max = value × 1048576 bytes).
# Default: 2048
SPIRAL_WORKER_MEM_LIMIT_MB=2048
#
# CPU quota as a percentage of one CPU core (maps to cpu.max quota/period).
# 80 = worker may use at most 80% of one CPU (cpu.max = "80000 100000").
# Default: 80
SPIRAL_WORKER_CPU_QUOTA=80

# ── Worker memory limits (Node.js V8 heap) ───────────────────────────────────
# V8 --max-old-space-size cap passed to claude CLI workers (MB).
# Default: 1024
# SPIRAL_MEMORY_LIMIT=1024

# Per-parallel-worker override (overrides SPIRAL_MEMORY_LIMIT for parallel runs).
# Default: 2048
# SPIRAL_WORKER_MEMORY_LIMIT=2048

# ── Worker timeout ────────────────────────────────────────────────────────────
# Wall-clock timeout per worker in seconds (0 = unlimited).
# Default: 600
# SPIRAL_WORKER_TIMEOUT=600
