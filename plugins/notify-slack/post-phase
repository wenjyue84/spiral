#!/bin/bash
# Slack notification hook — POST-PHASE
#
# Receives story context JSON on stdin:
#   {
#     "iteration": N,
#     "spiral_run_id": "...",
#     "phase": "R|T|M|G|I|V|C",
#     "story_id": "...",
#     "timestamp_iso": "2026-03-15T..."
#   }
#
# Posts a message to Slack webhook (SLACK_WEBHOOK_URL env var).

set -euo pipefail

# Check if webhook is configured
if [[ -z "${SLACK_WEBHOOK_URL:-}" ]]; then
  exit 0  # Silently skip if not configured
fi

# Read context from stdin
context=$(cat)

# Extract fields from JSON (simple jq-like parsing for portability)
iteration=$(echo "$context" | grep -o '"iteration":[0-9]*' | cut -d: -f2)
phase=$(echo "$context" | grep -o '"phase":"[^"]*"' | cut -d'"' -f4)
story_id=$(echo "$context" | grep -o '"story_id":"[^"]*"' | cut -d'"' -f4)

# Friendly phase names
case "$phase" in
  R) phase_name="Research" ;;
  T) phase_name="Test Synthesis" ;;
  M) phase_name="Merge" ;;
  G) phase_name="Gate" ;;
  I) phase_name="Implement" ;;
  V) phase_name="Validate" ;;
  C) phase_name="Check Done" ;;
  *) phase_name="Unknown ($phase)" ;;
esac

# Build Slack message payload
payload=$(cat <<EOF
{
  "text": "SPIRAL Phase Complete",
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*SPIRAL Phase Complete*\nIteration: \`${iteration:-0}\`\nPhase: \`${phase_name}\`\nStory: \`${story_id:-(none)}\`"
      }
    }
  ]
}
EOF
)

# Send to Slack (ignore errors to avoid breaking SPIRAL if webhook fails)
curl -s -X POST "$SLACK_WEBHOOK_URL" \
  -H 'Content-type: application/json' \
  --data "$payload" >/dev/null 2>&1 || true

exit 0
